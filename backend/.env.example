PORT=5000
MONGO_URI=your_mongodb_atlas_connection_string_here
JWT_SECRET=replace_with_a_long_random_string
ENCRYPTION_KEY=replace_with_a_32_byte_hex_key_see_readme
CLIENT_URL=http://localhost:5173

# Required for two-factor OTP emails at registration.
# Use a Gmail "App Password", NOT your normal Gmail password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification on your Google account (if not already on)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate an app password for "Mail" - copy the 16-character code
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_char_app_password
